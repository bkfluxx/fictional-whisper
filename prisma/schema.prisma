generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Stores the encrypted DEK (Data Encryption Key).
// There is exactly one row, inserted by scripts/create-user.ts at first run.
model KeyStore {
  id           String   @id @default("singleton")
  encryptedDek String   // base64( AES-256-GCM( DEK, KEK ) )
  dekSalt      String   // base64 Argon2id salt used to derive KEK from password
  // Optional second copy of the DEK wrapped with BACKUP_SECRET, used by the
  // nightly backup cron (which can't log in interactively).
  backupDek    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Single user. Password hash stored here for NextAuth credentials provider.
model User {
  id           String   @id @default(cuid())
  passwordHash String
  createdAt    DateTime @default(now())
}

model Entry {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  // The date the entry is "about" — can differ from createdAt (e.g. backdated imports)
  entryDate   DateTime
  title       String?       // AES-256-GCM encrypted, nullable
  body        String        // AES-256-GCM encrypted
  // Mood is NOT encrypted — stored as a plain slug so it can be queried/charted
  mood        String?
  // Categories — multi-value tags like "gratitude", "goals", "brain-dump". Not encrypted.
  categories  String[]      @default([])
  tags        Tag[]         @relation("EntryTags")
  attachments Attachment[]
  tokens      SearchToken[]
  // AI-generated fields (Phase 2). summary is encrypted; aiMood is a plain slug.
  summary     String?
  aiMood      String?
  // pgvector embedding (nomic-embed-text = 768 dims). Prisma doesn't support vector
  // natively so it's typed as Unsupported. Populated by the AI embedding pipeline.
  embedding   Unsupported("vector(768)")?

  @@index([entryDate])
  @@index([mood])
}

model Tag {
  id      String  @id @default(cuid())
  name    String  @unique
  entries Entry[] @relation("EntryTags")
}

model Attachment {
  id        String   @id @default(cuid())
  entryId   String
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  filename  String
  mimeType  String
  // AES-256-GCM encrypted file bytes. Max 10 MB enforced in the API route.
  data      Bytes
  createdAt DateTime @default(now())
}

// HMAC-SHA256 search tokens. Each row is HMAC(word, SEARCH_HMAC_SECRET).
// Allows keyword search without storing plaintext in a searchable column.
// IMPORTANT: If SEARCH_HMAC_SECRET changes, this table must be fully rebuilt
// via scripts/reindex-search.ts.
model SearchToken {
  id      String @id @default(cuid())
  entryId String
  entry   Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  token   String // hex HMAC

  @@index([token])
  @@index([entryId])
}

model ChatSession {
  id        String        @id @default(cuid())
  title     String        // first user message, truncated to ~60 chars
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // "user" | "assistant"
  content   String      // AES-256-GCM encrypted
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

// User-created journal templates. Built-in templates are defined in src/lib/templates.ts
// and never stored here.
model JournalTemplate {
  id          String   @id @default(cuid())
  title       String
  description String?
  emoji       String   @default("📝")
  body        String   // full markdown body prefilled in the editor
  categories  String[] @default([]) // suggested categories to pre-select
  // Built-in override support (mirrors UserCategory pattern)
  builtinId   String?  @unique  // links to a BUILT_IN_TEMPLATES id; null = user-created
  hidden      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WeeklyDigest {
  id         String   @id @default(cuid())
  weekStart  DateTime // Monday 00:00 UTC of the week the entries cover
  content    String   // AES-256-GCM encrypted markdown digest
  entryCount Int      // how many entries were included
  createdAt  DateTime @default(now())

  @@index([weekStart])
}

// User-defined categories and built-in overrides.
// builtinId links to a JOURNAL_TYPES id — null means user-defined.
// hidden = true removes the category from the picker (soft-delete for built-ins).
model UserCategory {
  id          String   @id @default(cuid())
  name        String
  emoji       String   @default("📝")
  description String?
  builtinId   String?  @unique  // e.g. "brain-dump"; null = user-defined
  hidden      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model AppSettings {
  id                  String    @id @default("singleton")
  backupPath          String    @default("/app/backups")
  backupRetainCount   Int       @default(30)
  lastBackupAt        DateTime?
  lastBackupSuccess   Boolean?
  lastBackupSizeBytes Int?
  // Onboarding
  onboardingDone        Boolean  @default(false)
  // User profile collected during onboarding
  userName              String?
  journalingIntention   String[] @default([]) // e.g. ["self-reflection", "gratitude"]
  writingStyle          String?              // "prompts" | "blank"
  // AI configuration (null = fall back to env vars)
  ollamaBaseUrl         String?  // overrides OLLAMA_BASE_URL; set during onboarding or in Settings
  ollamaModel           String?
  ollamaEmbedModel      String?
  chatSystemPrompt      String?  // custom system prompt for RAG chat (null = use hardcoded default)
  // Personas
  personasEnabled     Boolean  @default(false)
  activePersonaId     String?  // "builtin:<id>" for built-ins, or a Persona.id cuid for custom
}

// Stores the last AI-generated longitudinal insight. Single row (singleton id).
model AiInsight {
  id          String   @id @default("singleton")
  content     String   // AES-256-GCM encrypted
  entryCount  Int
  rangeFrom   DateTime // inclusive start of the analysed date range
  rangeTo     DateTime // inclusive end of the analysed date range
  generatedAt DateTime @default(now()) @updatedAt
}

// User-created AI personas. Built-in personas are defined in src/lib/personas.ts (not stored here).
model Persona {
  id           String   @id @default(cuid())
  name         String
  description  String?
  systemPrompt String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
