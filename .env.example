# Copy this to .env.local and fill in all values before running.

# --- Database ---
DATABASE_URL="postgresql://fw:changeme@localhost:5432/fictional_whisper"
POSTGRES_PASSWORD="changeme"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"

# --- Search HMAC ---
# Generate with: openssl rand -base64 32
# IMPORTANT: Never change this after entries have been indexed. Changing it
# invalidates the entire SearchToken table. Run scripts/reindex-search.ts to rebuild.
SEARCH_HMAC_SECRET="replace-with-random-32-char-string"

# --- Backup ---
# Absolute path inside the container where pg_dump files are written.
# Mount a host directory to this path in docker-compose.yml.
BACKUP_PATH="/app/backups"
# Secret used to encrypt the DEK copy stored for the scheduled backup process.
# Generate with: openssl rand -base64 32
BACKUP_SECRET="replace-with-random-32-char-string"

# --- Ollama (Phase 2) ---
# OLLAMA_URL="http://ollama:11434"
# OLLAMA_GENERATION_MODEL="phi3:mini"
# OLLAMA_EMBEDDING_MODEL="nomic-embed-text"
