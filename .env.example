# Copy this file to .env and fill in all CHANGE_ME values before running.
# Generate secrets with: openssl rand -base64 32

# ─── Database ─────────────────────────────────────────────────────────────────
# Use the Docker service name "db" as the host — NOT "localhost".
DATABASE_URL="postgresql://fw:CHANGE_ME@db:5432/fictional_whisper"

# Must match the password in DATABASE_URL above.
POSTGRES_PASSWORD="CHANGE_ME"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Random secret used to sign session tokens. Generate: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME"

# Public URL of your instance — no trailing slash.
# Unraid/PikaPods: set this to your actual domain or IP, e.g. http://192.168.1.10:3000
NEXTAUTH_URL="http://localhost:3000"

# ─── Search ───────────────────────────────────────────────────────────────────
# HMAC secret for keyword search indexing. Generate: openssl rand -base64 32
# WARNING: changing this after entries exist requires re-running scripts/reindex-search.ts
SEARCH_HMAC_SECRET="CHANGE_ME"

# ─── Backups ──────────────────────────────────────────────────────────────────
# Path inside the container where backups are written (maps to the backups volume).
BACKUP_PATH="/app/backups"

# Optional: encrypts the backup DEK copy. Leave blank to skip backup encryption.
# Generate: openssl rand -base64 32
# WARNING: changing this after backups exist makes old backups unreadable.
BACKUP_SECRET=""

# ─── AI / Ollama (optional) ───────────────────────────────────────────────────
# Leave blank — configure later through Settings → AI, or set defaults here.
# Unraid: use host.docker.internal to reach Ollama on the host.
# OLLAMA_BASE_URL="http://host.docker.internal:11434"
# OLLAMA_MODEL="qwen3:5b"
# OLLAMA_EMBED_MODEL="qwen3-embedding"
