generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Stores the encrypted DEK (Data Encryption Key).
// There is exactly one row, inserted by scripts/create-user.ts at first run.
model KeyStore {
  id           String   @id @default("singleton")
  encryptedDek String   // base64( AES-256-GCM( DEK, KEK ) )
  dekSalt      String   // base64 Argon2id salt used to derive KEK from password
  // Optional second copy of the DEK wrapped with BACKUP_SECRET, used by the
  // nightly backup cron (which can't log in interactively).
  backupDek    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Single user. Password hash stored here for NextAuth credentials provider.
model User {
  id           String   @id @default(cuid())
  passwordHash String
  createdAt    DateTime @default(now())
}

model Entry {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  // The date the entry is "about" — can differ from createdAt (e.g. backdated imports)
  entryDate   DateTime
  title       String?       // AES-256-GCM encrypted, nullable
  body        String        // AES-256-GCM encrypted
  // Mood is NOT encrypted — stored as a plain slug so it can be queried/charted
  mood        String?
  // Journal type slug — e.g. "brain-dump", "gratitude", "goals". Not encrypted.
  journalType String?
  tags        Tag[]         @relation("EntryTags")
  attachments Attachment[]
  tokens      SearchToken[]
  // AI-generated fields (Phase 2). summary is encrypted; aiMood is a plain slug.
  summary     String?
  aiMood      String?
  // pgvector embedding (nomic-embed-text = 768 dims). Prisma doesn't support vector
  // natively so it's typed as Unsupported. Populated by the AI embedding pipeline.
  embedding   Unsupported("vector(768)")?

  @@index([entryDate])
  @@index([mood])
  @@index([journalType])
}

model Tag {
  id      String  @id @default(cuid())
  name    String  @unique
  entries Entry[] @relation("EntryTags")
}

model Attachment {
  id        String   @id @default(cuid())
  entryId   String
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  filename  String
  mimeType  String
  // AES-256-GCM encrypted file bytes. Max 10 MB enforced in the API route.
  data      Bytes
  createdAt DateTime @default(now())
}

// HMAC-SHA256 search tokens. Each row is HMAC(word, SEARCH_HMAC_SECRET).
// Allows keyword search without storing plaintext in a searchable column.
// IMPORTANT: If SEARCH_HMAC_SECRET changes, this table must be fully rebuilt
// via scripts/reindex-search.ts.
model SearchToken {
  id      String @id @default(cuid())
  entryId String
  entry   Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  token   String // hex HMAC

  @@index([token])
  @@index([entryId])
}

model AppSettings {
  id                  String    @id @default("singleton")
  backupPath          String    @default("/app/backups")
  backupRetainCount   Int       @default(30)
  lastBackupAt        DateTime?
  lastBackupSuccess   Boolean?
  lastBackupSizeBytes Int?
  // Onboarding
  onboardingDone      Boolean   @default(false)
  journalTypes        String[]  @default([])
  // AI configuration (null = fall back to env vars)
  ollamaBaseUrl       String?   // overrides OLLAMA_BASE_URL; set during onboarding or in Settings
  ollamaModel         String?
  ollamaEmbedModel    String?
}
